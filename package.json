{
  "name": "manyumba",
  "private": true,
  "scripts": {
    "dev": "turbo dev --filter=user-docs --filter=web",
    "dev:start": "node scripts/dev.mjs",
    "dev:stop": "node scripts/dev.mjs --stop",
    "dev:reset": "node scripts/dev.mjs --reset",
    "build": "turbo build",
    "cleanup": "turbo cleanup",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "typecheck": "turbo typecheck",
    "release": "turbo release && changeset",
    "build:docs": "turbo build --filter=docs",
    "build:web": "turbo build --filter=web",
    "dev:docs": "turbo dev --filter=docs",
    "dev:web": "turbo dev --filter=web",
    "test": "turbo test"
  },
  "devDependencies": {
    "@chiballc/types": "^0.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "turbo": "^2.9.3",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "nuxt": "^4.4.2"
  }
}
